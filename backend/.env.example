PORT=3000
NODE_ENV=development

# Database
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DATABASE_URL=

# Apple Sign In
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=

# JWT / Session
SESSION_SECRET=
SESSION_EXPIRES_IN=7d

# Pairing token TTL (seconds)
PAIRING_TOKEN_TTL=300

# Dose scheduler (in-process sweep)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000

# APNS push (reuses APPLE_TEAM_ID / APPLE_KEY_ID above)
APNS_TOPIC=
APNS_HOST=api.sandbox.push.apple.com
# .p8 push key PEM, newlines escaped as \n
APNS_KEY_P8=
